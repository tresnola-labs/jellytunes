{
  "name": "jellysync",
  "version": "1.1.0",
  "description": "Sincronizador de música Jellyfin → dispositivos MP3/FLAC",
  "main": "dist/main/index.js",
  "author": "Jellysync Team",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite build && electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "test:bdd": "pnpm build && TS_NODE_PROJECT=tests/bdd/tsconfig.json cucumber-js --config tests/bdd/cucumber.js",
    "test:bdd:dev": "pnpm build && TS_NODE_PROJECT=tests/bdd/tsconfig.json cucumber-js --config tests/bdd/cucumber.js --profile dev",
    "test:bdd:ci": "pnpm build && TS_NODE_PROJECT=tests/bdd/tsconfig.json cucumber-js --config tests/bdd/cucumber.js --profile ci",
    "test:bdd:report": "open tests/bdd/reports/cucumber-report.html",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "better-sqlite3": "^11.6.0",
    "electron-log": "^5.2.4",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.1",
    "@cucumber/pretty-formatter": "^1.0.1",
    "@playwright/test": "^1.40.1",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "playwright": "^1.40.1",
    "postcss": "^8.4.49",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.jellysync.app",
    "productName": "Jellysync",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    }
  }
}
